---
/**
 * AppHeader — the static site header.
 *
 * Editorial-stationery register (#163): a serif wordmark + a short serif
 * tagline on the left; the current-file chip (mono, file metaphor kept on
 * purpose) on the right.
 */
---

<header class="app-header">
  <div class="app-header__brand">
    <h1 class="app-header__name">Works&nbsp;on&nbsp;My&nbsp;Resume</h1>
    <p class="app-header__tagline">Markdown in. Resume out.</p>
  </div>
  <span class="app-header__tab" aria-hidden="true">
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
      <path d="M14 2v6h6"></path>
    </svg>
    <code class="app-header__tab-name">resume.md</code>
  </span>
</header>
