---
/**
 * AppHeader — the static site header, styled like a real editor titlebar.
 *
 * Left: a faux window-control dot cluster and a heavy JetBrains Mono
 * wordmark with a shell-prompt glyph. Right: a `~/resume.md` chip that reads
 * like an open-file tab. A couple of editor cues, no gimmickry.
 */
---

<header class="app-header">
  <div class="app-header__brand">
    <span class="app-header__dots" aria-hidden="true">
      <span class="app-header__dot"></span>
      <span class="app-header__dot"></span>
      <span class="app-header__dot"></span>
    </span>
    <span class="app-header__prompt" aria-hidden="true">&rsaquo;_</span>
    <h1 class="app-header__name">Works&nbsp;on&nbsp;My&nbsp;Resume</h1>
    <p class="app-header__tagline">Markdown in. Resume out. No servers harmed.</p>
  </div>
  <span class="app-header__tab" aria-hidden="true">
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
      <path d="M14 2v6h6"></path>
    </svg>
    <code class="app-header__tab-name">~/resume.md</code>
  </span>
</header>
