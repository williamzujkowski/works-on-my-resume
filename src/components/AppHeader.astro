---
/**
 * AppHeader — the static site header.
 *
 * Terminal/editor flavored: a faux shell prompt glyph, the product name and
 * tagline, and a monospace "path label" pinned to the trailing edge. Kept
 * tasteful — a couple of cues, no gimmickry.
 */
---

<header class="app-header">
  <div class="app-header__brand">
    <span class="app-header__prompt" aria-hidden="true">&rsaquo;_</span>
    <h1 class="app-header__name">Works on My Resume</h1>
    <p class="app-header__tagline">Markdown in. Resume out. No servers harmed.</p>
  </div>
  <code class="app-header__path">~/resume.md</code>
</header>
