---
/**
 * index.astro — the single page of Works on My Resume.
 *
 * Renders the static Astro chrome (header, privacy notice) and mounts the
 * `ResumeStudio` React island, which owns all interactive app state.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/AppHeader.astro';
import PrivacyNotice from '../components/PrivacyNotice.astro';
import ResumeStudio from '../components/ResumeStudio.tsx';
---

<BaseLayout>
  <a class="skip-link" href="#studio">Skip to the resume workbench</a>
  <div class="app-shell">
    {
      /* Each direct child carries a --i index that drives the staggered
        page-load reveal in global.css. Collapses to the final state
        instantly under prefers-reduced-motion. */
    }
    <div class="reveal delay-0">
      <AppHeader />
    </div>
    <div class="reveal delay-1">
      <PrivacyNotice />
    </div>
    <main id="studio" class="reveal delay-2">
      <ResumeStudio client:load />
    </main>
  </div>
</BaseLayout>
