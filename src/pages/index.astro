---
/**
 * index.astro — the single page of Works on My Resume.
 *
 * Renders the static Astro chrome (header, privacy notice) and mounts the
 * `ResumeStudio` React island, which owns all interactive app state.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/AppHeader.astro';
import PrivacyNotice from '../components/PrivacyNotice.astro';
import ResumeStudio from '../components/ResumeStudio.tsx';
---

<BaseLayout>
  <a class="skip-link" href="#studio">Skip to the resume workbench</a>
  <div class="app-shell">
    {
      /* The three direct children fade + rise in sequence — the stagger is
        driven by `:nth-child` animation-delays in global.css (NOT inline
        `style="--i"`, which would need `style-src-attr 'unsafe-inline'` and
        trip the strict CSP, #243). Collapses to the final state instantly
        under prefers-reduced-motion. */
    }
    <div class="reveal">
      <AppHeader />
    </div>
    <div class="reveal">
      <PrivacyNotice />
    </div>
    <main id="studio" class="reveal">
      <ResumeStudio client:load />
    </main>
  </div>
</BaseLayout>
