---
/**
 * index.astro — the single page of Works on My Resume.
 *
 * Renders the static Astro chrome (header, privacy notice) and mounts the
 * `ResumeStudio` React island, which owns all interactive app state.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/AppHeader.astro';
import PrivacyNotice from '../components/PrivacyNotice.astro';
import ResumeStudio from '../components/ResumeStudio.tsx';
---

<BaseLayout>
  <a class="skip-link" href="#studio">Skip to the resume workbench</a>
  <div class="app-shell">
    <AppHeader />
    <PrivacyNotice />
    <main id="studio">
      <ResumeStudio client:load />
    </main>
  </div>
</BaseLayout>
