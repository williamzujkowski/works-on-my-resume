---
/**
 * BaseLayout — the single HTML shell for Works on My Resume.
 *
 * Owns <head>, the Content Security Policy, metadata, and the global
 * stylesheet import. Pages fill the <slot />.
 *
 * Privacy posture: this is a fully static site. There are no analytics,
 * no third-party scripts, and no network calls that carry resume content.
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Works on My Resume',
  description = 'A static, local-first Markdown resume renderer with OKLCH terminal themes. Markdown in. Resume out. No servers harmed.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {
      /*
      Content Security Policy is now emitted by Astro itself (#38).
      `security.csp` in `astro.config.mjs` lists the non-script/style
      directives; Astro builds `script-src` / `style-src` from the SHA-256
      hashes it computes for every inline <script> and <style> it emits
      (island hydration glue, scoped component CSS). The page therefore
      ships without `'unsafe-inline'` on either directive.

      Dynamic per-theme swatch colors used to require `style-src
      'unsafe-inline'`; the components now write those colors via the CSSOM
      (`el.style.setProperty(...)`) in a `useLayoutEffect`. CSSOM mutations
      from script are governed by `script-src`, not `style-src`, so they
      bypass the inline-style restriction entirely.

      connect-src exception — `https://api.github.com` (#33):
      A single, deliberate allowance so the user-initiated "Import from
      Gist" flow can call the public Gists API. The fetch ONLY happens
      when the user pastes a gist URL and explicitly clicks Import; it
      sends no auth, no resume content, and no other data outbound. This
      is the lone exception to the otherwise self-only `connect-src` and is
      preserved as a literal entry in `security.csp.directives`.
    */
    }

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Open Graph: theme-only metadata, never resume content. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>
