---
/**
 * BaseLayout — the single HTML shell for Works on My Resume.
 *
 * Owns <head>, the Content Security Policy, metadata, and the global
 * stylesheet import. Pages fill the <slot />.
 *
 * Privacy posture: this is a fully static site. There are no analytics,
 * no third-party scripts, and no network calls that carry resume content.
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Works on My Resume',
  description = 'A static, local-first Markdown resume renderer with OKLCH terminal themes. Markdown in. Resume out. No servers harmed.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!--
      Content Security Policy. The site is static and local-first: resume
      content is parsed and sanitized (DOMPurify) entirely in the browser
      and is never transmitted. img-src allows data:/blob: but no remote
      hosts, so a malicious resume cannot beacon out via an <img>.
      'unsafe-inline' is currently required for Astro's island hydration
      scripts and for the theme picker's dynamic per-theme swatch colors;
      tightening this to hashes is tracked in issue #38.

      connect-src exception — `https://api.github.com` (#33):
      A single, deliberate allowance so the user-initiated "Import from
      Gist" flow can call the public Gists API. The fetch ONLY happens
      when the user pastes a gist URL and explicitly clicks Import; it
      sends no auth, no resume content, and no other data outbound. This
      is the lone exception to the otherwise self-only `connect-src`.
    -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://api.github.com; object-src 'none'; base-uri 'self'; form-action 'none';"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Open Graph: theme-only metadata, never resume content. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>
